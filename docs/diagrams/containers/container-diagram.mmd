%% C4 Nivel 2: Diagrama de Containers — Mestra AI
%% Referencia: docs/blueprint/06-system-architecture.md
%%
%% Arquitetura: Monolito Node.js + CLI
%% Sem UI, sem mensageria, pipeline sincrono

graph TB
    %% -------------------------------------------------------
    %% Atores
    %% -------------------------------------------------------
    Operator["👤 Operador de Canal<br/>Executa pipeline via CLI"]

    %% -------------------------------------------------------
    %% Fronteira do Sistema
    %% -------------------------------------------------------
    subgraph SystemBoundary["🏢 Mestra AI - Sistema Autonomo de Crescimento"]
        direction TB

        %% CLI Entry Point
        CLI["💻 Mestra CLI<br/>Node.js/TypeScript<br/>Ponto de entrada via commander"]

        %% Pipeline Orchestrator
        Pipeline["🔄 Pipeline Orchestrator<br/>TypeScript<br/>Coordena steps, retry, estado"]

        subgraph Engines["⚙️ Engines"]
            direction LR
            Content["📝 Content<br/>Ideias, roteiros, hooks"]
            Scene["🎬 Scene<br/>Segmentacao, duracao"]
            Voice["🔊 Voice<br/>TTS ElevenLabs"]
            Visual["🖼️ Visual<br/>Busca Pexels"]
            Pacing["⚡ Pacing<br/>Ritmo, interrupcoes"]
            Render["🎥 Rendering<br/>FFmpeg, legendas"]
            Thumb["🖼️ Thumbnail<br/>CTR scoring"]
            Performance["📊 Performance<br/>YouTube Analytics"]
            Strategy["🎯 Strategy<br/>Plano de conteudo"]
            Learning["🧠 Learning<br/>Ajuste de pesos"]
        end

        %% Storage
        DB[(🗄️ SQLite/PostgreSQL<br/>Prisma ORM)]
        Storage["📁 Disco Local<br/>Videos, thumbnails"]
    end

    %% -------------------------------------------------------
    %% Sistemas Externos
    %% -------------------------------------------------------
    OpenRouter["📦 OpenRouter<br/>Gateway LLM"]
    ElevenLabs["📦 ElevenLabs<br/>Text-to-Speech"]
    Pexels["📦 Pexels API<br/>Videos/Imagens"]
    FFmpeg["📦 FFmpeg CLI<br/>Renderizacao"]
    YouTubeData["📦 YouTube Data API<br/>Upload"]
    YouTubeAnalytics["📦 YouTube Analytics<br/>Metricas"]
    DALLE["📦 DALL-E/SDXL<br/>Imagens thumbnail"]

    %% -------------------------------------------------------
    %% Relacionamentos — Operador
    %% -------------------------------------------------------
    Operator -->|"Executa pipeline"| CLI

    %% -------------------------------------------------------
    %% Relacionamentos — CLI -> Pipeline
    %% -------------------------------------------------------
    CLI -->|"Chama"| Pipeline

    %% -------------------------------------------------------
    %% Relacionamentos — Pipeline -> Engines
    %% -------------------------------------------------------
    Pipeline -->|"1. Gera"| Content
    Pipeline -->|"2. Segmenta"| Scene
    Pipeline -->|"3a. Audio"| Voice
    Pipeline -->|"3b. Visual"| Visual
    Pipeline -->|"4. Aplica"| Pacing
    Pipeline -->|"5. Renderiza"| Render
    Pipeline -->|"6. Gera"| Thumb
    Pipeline -->|"7. Upload"| YouTubeData
    Pipeline -->|"Coleta"| Performance

    %% -------------------------------------------------------
    %% Relacionamentos — Engines -> Engines
    %% -------------------------------------------------------
    Strategy -.->|"Diretiva"| Content
    Learning -.->|"Pesos"| Content
    Performance -->|"Dados"| Learning
    Learning -->|"Estado"| Strategy

    %% -------------------------------------------------------
    %% Relacionamentos — Pipeline -> Dados
    %% -------------------------------------------------------
    Pipeline <-->|"Persiste estado"| DB
    Pipeline -->|"Salva video"| Storage
    Pipeline -->|"Salva thumb"| Storage

    %% -------------------------------------------------------
    %% Relacionamentos — Engines -> APIs Externas
    %% -------------------------------------------------------
    Content -->|"LLM"| OpenRouter
    Voice -->|"TTS"| ElevenLabs
    Visual -->|"Busca"| Pexels
    Visual -->|"Gera"| DALLE
    Render -->|"Renderiza"| FFmpeg
    Thumb -->|"Gera"| DALLE
    Performance -->|"Metricas"| YouTubeAnalytics

    %% -------------------------------------------------------
    %% Estilos C4
    %% -------------------------------------------------------
    style SystemBoundary fill:none,stroke:#0b4884,stroke-width:2px,stroke-dasharray:5 5,color:#0b4884
    style CLI fill:#438dd5,stroke:#2e6295,color:#fff
    style Pipeline fill:#438dd5,stroke:#2e6295,color:#fff
    style Engines fill:#E3F2FD,stroke:#438DD5,stroke-width:1px,color:#333
    style Content fill:#438dd5,stroke:#2e6295,color:#fff
    style Scene fill:#438dd5,stroke:#2e6295,color:#fff
    style Voice fill:#438dd5,stroke:#2e6295,color:#fff
    style Visual fill:#438dd5,stroke:#2e6295,color:#fff
    style Pacing fill:#438dd5,stroke:#2e6295,color:#fff
    style Render fill:#438dd5,stroke:#2e6295,color:#fff
    style Thumb fill:#438dd5,stroke:#2e6295,color:#fff
    style Performance fill:#438dd5,stroke:#2e6295,color:#fff
    style Strategy fill:#438dd5,stroke:#2e6295,color:#fff
    style Learning fill:#438dd5,stroke:#2e6295,color:#fff
    style DB fill:#67BE4B,stroke:#4A9A35,color:#fff
    style Storage fill:#67BE4B,stroke:#4A9A35,color:#fff
    style Operator fill:#08427b,stroke:#052e56,color:#fff
    style OpenRouter fill:#999999,stroke:#6b6b6b,color:#fff
    style ElevenLabs fill:#999999,stroke:#6b6b6b,color:#fff
    style Pexels fill:#999999,stroke:#6b6b6b,color:#fff
    style FFmpeg fill:#999999,stroke:#6b6b6b,color:#fff
    style YouTubeData fill:#999999,stroke:#6b6b6b,color:#fff
    style YouTubeAnalytics fill:#999999,stroke:#6b6b6b,color:#fff
