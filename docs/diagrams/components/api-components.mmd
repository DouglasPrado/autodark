%% ============================================================
%% Componentes Internos — Mestra AI
%% Referência: docs/blueprint/06-system-architecture.md
%% ============================================================
%% Como o Mestra CLI e o Pipeline Orchestrator são organizados internamente

classDiagram
    direction TB

    %% --- Entry Point ---
    class CLI {
        +run(command, options) void
        +parseArgs() Command
    }

    %% --- Pipeline Core ---
    class PipelineOrchestrator {
        +execute(context) PipelineContext
        +executeStep(step, context) PipelineContext
        +retry(step, context) PipelineContext
        +persistState(context) void
    }

    class PipelineContext {
        +id: string
        +niche: string
        +status: string
        +contentPlan: ContentPlan
        +idea: Idea
        +script: Script
        +scenes: Scene[]
        +videoPath: string
        +thumbnailPath: string
        +metrics: VideoMetrics
    }

    %% --- Engines ---
    class ContentEngine {
        +generateIdea(niche, directive) Idea
        +generateScriptFromTemplate(idea, template) Script
        +generateHookVariants(idea) Hook[]
        +selectBestHook(hooks) Hook
    }

    class SceneEngine {
        +splitIntoScenes(script) Scene[]
        +estimateDurations(scenes) Scene[]
        +generateVisualQueries(scene) string
    }

    class VoiceEngine {
        +generateVoice(scene) AudioSegment
        +applyVoiceStyle(segment, profile) AudioSegment
        +mergeAudioSegments(segments) AudioSegment
    }

    class VisualEngine {
        +searchClips(query) Clip[]
        +rankClips(clips, scene) Clip[]
        +downloadMedia(clip) string
    }

    class PacingEngine {
        +enforceMaxSceneDuration(scenes) Scene[]
        +addPatternInterrupts(scenes) Scene[]
        +applyZoomEffects(scenes) Scene[]
        +addMicroTransitions(scenes) Scene[]
    }

    class RenderingEngine {
        +composeScene(scene) string
        +syncAudioVideo(scene) string
        +stitchScenes(scenes) string
        +addSubtitles(videoPath, scenes) string
        +addBackgroundMusic(videoPath) string
    }

    class ThumbnailEngine {
        +generateThumbnailConcepts(idea) string[]
        +generateMultipleImages(concepts) Image[]
        +composeThumbnail(image, text) string
        +scoreThumbnailCTR(thumbnail) number
        +selectBestThumbnail(thumbnails) Thumbnail
    }

    class PerformanceEngine {
        +collectMetrics(videoId) VideoMetrics
        +getRetentionCurve(metrics) RetentionCurve
        +detectDropOffPoints(metrics) number[]
        +scoreVideoPerformance(metrics) number
    }

    class StrategyEngine {
        +generateContentPlan(niche, metrics) ContentPlan
        +clusterTopics(topics) TopicCluster[]
        +prioritizeIdeas(ideas) Idea[]
        +createSeries(topic) Series
    }

    class LearningEngine {
        +analyzeFailures(metrics[]) LearningAnalysis
        +updatePromptWeights(analysis) Weights
        +adjustHookStrategy(weights) HookStrategy
        +optimizeTemplates(analysis) TemplateConfig
    }

    %% --- Upload ---
    class UploadModule {
        +generateTitle(idea) string
        +generateDescription(script) string
        +generateTags(idea, script) string[]
        +uploadToYoutube(video, thumbnail, metadata) string
    }

    %% --- Database ---
    class DatabaseClient {
        +savePipeline(context) Pipeline
        +getPipeline(id) Pipeline
        +updatePipelineStatus(id, status) void
        +saveMetrics(metrics) VideoMetrics
        +getLearningState(niche) LearningState
        +updateLearningState(state) void
    }

    %% --- Relationships ---
    CLI --> PipelineOrchestrator : "run()"

    PipelineOrchestrator --> PipelineContext : "mantém estado"
    PipelineOrchestrator --> DatabaseClient : "persiste"

    PipelineOrchestrator --> ContentEngine : "gera conteúdo"
    PipelineOrchestrator --> SceneEngine : "segmenta"
    PipelineOrchestrator --> VoiceEngine : "áudio"
    PipelineOrchestrator --> VisualEngine : "visuais"
    PipelineOrchestrator --> PacingEngine : "ritmo"
    PipelineOrchestrator --> RenderingEngine : "renderiza"
    PipelineOrchestrator --> ThumbnailEngine : "thumbnail"
    PipelineOrchestrator --> UploadModule : "upload"
    PipelineOrchestrator --> PerformanceEngine : "métricas"

    ContentEngine --> StrategyEngine : "recebe diretiva"
    ContentEngine --> LearningEngine : "recebe pesos"
    PerformanceEngine --> LearningEngine : "fornece dados"
    LearningEngine --> StrategyEngine : "atualiza"

    UploadModule --> YouTubeDataAPI : "HTTP"
    VoiceEngine --> ElevenLabsAPI : "HTTP"
    VisualEngine --> PexelsAPI : "HTTP"
    ContentEngine --> OpenRouterAPI : "HTTP"
    RenderingEngine --> FFmpeg : "CLI"
    ThumbnailEngine --> DALLEAPI : "HTTP"
    PerformanceEngine --> YouTubeAnalyticsAPI : "HTTP"
