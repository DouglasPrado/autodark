%% ============================================================
%% Diagrama de Deploy Escalado: Mestra AI
%% Versão simplificada -CLI com workers
%% Referências:
%%   - docs/blueprint/14-scalability.md
%%   - docs/blueprint/06-system-architecture.md
%% ============================================================

graph TB

    %% ===========================================================
    %% CAMADA: Scheduler
    %% ===========================================================
    subgraph SCHEDULER["⏰ Agendamento"]
        Cron["Cron / systemd<br/>Dispara pipelines"]
    end

    %% ===========================================================
    %% CAMADA: Servidor Principal
    %% ===========================================================
    subgraph SERVER["🖥️ Servidor Principal"]
        direction TB

        subgraph APP["Mestra AI - Main"]
            CLI["💻 CLI<br/>Ponto de entrada"]
            Pipeline["🔄 Pipeline<br/>Orchestrator"]
        end

        subgraph WORKERS["⚙️ Workers (futuro)"]
            RenderWorker["🎬 Render Worker<br/>FFmpeg"]
            MetricsWorker["📊 Metrics Worker<br/>YouTube API"]
        end

        subgraph STORAGE["📁 Armazenamento"]
            Videos["🎬 Videos<br/>Videos renderizados"]
            Assets["📦 Assets Cache<br/>Clips/audios"]
            DB["🗄️ PostgreSQL<br/>Pipelines, metrics"]
        end
    end

    %% ===========================================================
    %% CAMADA: APIs Externas
    %% ===========================================================
    subgraph EXTERNALS["☁️ Serviços Externos"]
        OpenRouter["📦 OpenRouter<br/>LLM"]
        ElevenLabs["📦 ElevenLabs<br/>TTS"]
        Pexels["📦 Pexels API<br/>Videos/Imagens"]
        FFmpeg["📦 FFmpeg CLI<br/>Renderização"]
        YouTube["📦 YouTube APIs<br/>Data + Analytics"]
        DALLE["📦 DALL-E/SDXL<br/>Thumbnails"]
    end

    %% ===========================================================
    %% CONEXÕES - Fase 1 (básico)
    %% ===========================================================

    %% Scheduler -> Main
    Cron -->|"Dispara"| CLI

    %% Main Pipeline
    CLI --> Pipeline
    Pipeline <-->|"Persiste"| DB
    Pipeline -->|"Salva"| Videos
    Pipeline -->|"Cache"| Assets

    %% APIs
    Pipeline -->|"LLM"| OpenRouter
    Pipeline -->|"TTS"| ElevenLabs
    Pipeline -->|"Busca"| Pexels
    Pipeline -->|"Renderiza"| FFmpeg
    Pipeline -->|"Upload"| YouTube
    Pipeline -->|"Gera"| DALLE

    %% Metrics (async)
    Cron -->|"Coleta"| MetricsWorker
    MetricsWorker -->|"API"| YouTube
    MetricsWorker <-->|"Persiste"| DB

    %% ===========================================================
    %% CONEXÕES - Fase 2 (com workers)
    %% ===========================================================
    
    %% Future: Workers separados
    note right of SERVER
        Fase 2: Workers separados
        - Render Worker para FFmpeg
        - Metrics Worker para YouTube API
        - Auto-scaling se >20 videos/dia
    end

    %% ===========================================================
    %% ESTILOS
    %% ===========================================================
    style SCHEDULER fill:#FFF3E0,stroke:#F5A623,stroke-width:2px,color:#333
    style Cron fill:#F5A623,stroke:#E09100,color:#fff
    
    style SERVER fill:#E3F2FD,stroke:#438DD5,stroke-width:2px,color:#333
    style APP fill:#E3F2FD,stroke:#438DD5,stroke-width:1px,color:#333
    style CLI fill:#438DD5,stroke:#2B6CB0,color:#fff
    style Pipeline fill:#438DD5,stroke:#2B6CB0,color:#fff
    style WORKERS fill:#E3F2FD,stroke:#438DD5,stroke-width:1px,color:#333
    style RenderWorker fill:#438DD5,stroke:#2B6CB0,color:#fff
    style MetricsWorker fill:#438DD5,stroke:#2B6CB0,color:#fff
    
    style STORAGE fill:#E8F5E9,stroke:#67BE4B,stroke-width:1px,color:#333
    style Videos fill:#67BE4B,stroke:#4A9A35,color:#fff
    style Assets fill:#67BE4B,stroke:#4A9A35,color:#fff
    style DB fill:#67BE4B,stroke:#4A9A35,color:#fff
    
    style EXTERNALS fill:#FFF3E0,stroke:#F5A623,stroke-width:1px,color:#333
    style OpenRouter fill:#999999,stroke:#6b6b6b,color:#fff
    style ElevenLabs fill:#999999,stroke:#6b6b6b,color:#fff
    style Pexels fill:#999999,stroke:#6b6b6b,color:#fff
    style FFmpeg fill:#999999,stroke:#6b6b6b,color:#fff
    style YouTube fill:#999999,stroke:#6b6b6b,color:#fff
    style DALLE fill:#999999,stroke:#6b6b6b,color:#fff
