%% ============================================================
%% Diagrama de Deploy: Produção — Mestra AI
%% Referências:
%%   - docs/blueprint/06-system-architecture.md
%% ============================================================
%% Arquitetura: Monolito Node.js executado via PM2/systemd
%% Sem load balancer, sem cache externo, sem mensageria

graph TB

    %% ===========================================================
    %% CAMADA: Servidor / VPS
    %% ===========================================================
    subgraph SERVER["🖥️ Servidor — VPS / EC2 / Droplet"]
        direction TB

        subgraph APP["Mestra AI - Monolito Node.js"]
            direction LR
            CLI["💻 CLI<br/>Ponto de entrada"]
            Runtime["⚙️ Node.js 20+<br/>Runtime"]
            Engines["⚙️ Engines<br/>Content, Scene, Voice,<br/>Visual, Pacing, Render,<br/>Thumbnail, Performance,<br/>Strategy, Learning"]
        end

        subgraph STORAGE["📁 Armazenamento Local"]
            Videos["🎬 Videos<br/>Videos renderizados"]
            Thumbnails["🖼️ Thumbnails<br/>Thumbnails geradas"]
            Assets["📦 Assets Cache<br/>Clips/audios baixados"]
        end

        DB["🗄️ PostgreSQL<br/>Pipelines, metrics,<br/>learning states"]
    end

    %% ===========================================================
    %% CAMADA: Agendamento (opcional)
    %% ===========================================================
    subgraph SCHEDULER["⏰ Agendamento"]
        Cron["⏱️ Cron / systemd timer<br/>Executa pipeline<br/>10+ videos/dia"]
    end

    %% ===========================================================
    %% Sistemas Externos
    %% ===========================================================
    subgraph EXTERNALS["☁️ Serviços Externos"]
        OpenRouter["📦 OpenRouter<br/>Gateway LLM"]
        ElevenLabs["📦 ElevenLabs<br/>Text-to-Speech"]
        Pexels["📦 Pexels API<br/>Videos/Imagens"]
        FFmpeg["📦 FFmpeg CLI<br/>Renderizacao local"]
        YouTubeData["📦 YouTube Data API<br/>Upload"]
        YouTubeAnalytics["📦 YouTube Analytics<br/>Metricas"]
        DALLE["📦 DALL-E/SDXL<br/>Imagens thumbnail"]
    end

    %% ===========================================================
    %% CONEXÕES
    %% ===========================================================

    %% Scheduler -> App
    Cron -->|"Dispara pipeline"| CLI

    %% App -> Engines
    CLI -->|"Executa"| Runtime
    Runtime -->|"Orquestra"| Engines

    %% Engines -> Databases/Storage
    Engines -->|"Persiste"| DB
    Engines -->|"Salva"| Videos
    Engines -->|"Salva"| Thumbnails
    Engines -->|"Cache"| Assets

    %% Engines -> APIs Externas
    Engines -->|"LLM"| OpenRouter
    Engines -->|"TTS"| ElevenLabs
    Engines -->|"Busca"| Pexels
    Engines -->|"Renderiza"| FFmpeg
    Engines -->|"Upload"| YouTubeData
    Engines -->|"Metricas"| YouTubeAnalytics
    Engines -->|"Gera"| DALLE

    %% ===========================================================
    %% ESTILOS
    %% ===========================================================
    style SERVER fill:#E3F2FD,stroke:#438DD5,stroke-width:2px,color:#333
    style APP fill:#E3F2FD,stroke:#438DD5,stroke-width:1px,color:#333
    style CLI fill:#438DD5,stroke:#2B6CB0,color:#fff
    style Runtime fill:#438DD5,stroke:#2B6CB0,color:#fff
    style Engines fill:#438DD5,stroke:#2B6CB0,color:#fff
    style STORAGE fill:#E8F5E9,stroke:#67BE4B,stroke-width:1px,color:#333
    style Videos fill:#67BE4B,stroke:#4A9A35,color:#fff
    style Thumbnails fill:#67BE4B,stroke:#4A9A35,color:#fff
    style Assets fill:#67BE4B,stroke:#4A9A35,color:#fff
    style DB fill:#67BE4B,stroke:#4A9A35,color:#fff
    style SCHEDULER fill:#FFF3E0,stroke:#F5A623,stroke-width:2px,color:#333
    style Cron fill:#F5A623,stroke:#E09100,color:#fff
    style EXTERNALS fill:#FFF3E0,stroke:#F5A623,stroke-width:1px,color:#333
    style OpenRouter fill:#999999,stroke:#6b6b6b,color:#fff
    style ElevenLabs fill:#999999,stroke:#6b6b6b,color:#fff
    style Pexels fill:#999999,stroke:#6b6b6b,color:#fff
    style FFmpeg fill:#999999,stroke:#6b6b6b,color:#fff
    style YouTubeData fill:#999999,stroke:#6b6b6b,color:#fff
    style YouTubeAnalytics fill:#999999,stroke:#6b6b6b,color:#fff
    style DALLE fill:#999999,stroke:#6b6b6b,color:#fff
