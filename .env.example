# Database
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/mestra?schema=public"

# OpenRouter (LLM)
OPENROUTER_API_KEY=""

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""

# Pexels (Visual Assets)
PEXELS_API_KEY=""

# YouTube Data API (Upload)
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
YOUTUBE_REDIRECT_URI="http://localhost:3000/oauth2callback"
YOUTUBE_REFRESH_TOKEN=""

# YouTube Analytics API (Metrics)
YOUTUBE_ANALYTICS_ENABLED="false"

# Image Generation (Thumbnails)
IMAGE_AI_PROVIDER="openrouter"

# Storage
STORAGE_PATH="./storage"

# Logging
LOG_LEVEL="info"

# Cron
METRICS_CRON="0 */6 * * *"
LEARNING_CRON="0 0 * * *"
